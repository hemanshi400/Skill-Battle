{
  "name": "skill-battle-backend",
  "version": "1.0.0",
  "description": "Backend API for Skill Battle weekend challenge platform",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --watch src -e ts --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:setup": "prisma db push && prisma db seed",
    "db:seed": "prisma db seed",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "nodemon": "^3.1.7",
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
